<Page
  xmlns="http://schemas.nativescript.org/tns.xsd"
  xmlns:wv="@modos189/nativescript-webview-x-gecko"
  navigatingTo="navigatingTo"
  class="page"
>
  <GridLayout rows="auto, *">
    <GridLayout row="0" columns="*, auto" class="p-8">
      <TextField
        col="0"
        hint="Enter URL"
        text="{{ url }}"
        returnKeyType="go"
        keyboardType="url"
        autocorrect="false"
        returnPress="{{ onNavigate }}"
        class="input"
      />
      <Button col="1" text="Go" tap="{{ onNavigate }}" class="btn btn-primary m-l-8" />
    </GridLayout>
    <wv:WebViewX
      row="1"
      src="{{ src }}"
      debugMode="true"
    />
  </GridLayout>
</Page>
