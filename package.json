{
  "name": "plugins",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "postinstall": "husky && npx ts-patch install && npx patch-package",
    "setup": "npx rimraf node_modules package-lock.json dist tmp yarn.lock && npm install",
    "start": "nps",
    "add": "nx g @nativescript/plugin-tools:add-package",
    "add-angular": "nx g @nativescript/plugin-tools:add-angular",
    "config": "nx g @nativescript/plugin-tools:config",
    "publish-packages": "nx g @nativescript/plugin-tools:publish",
    "sync-packages-with-demos": "nx g @nativescript/plugin-tools:sync-packages-with-demos",
    "remove-package": "nx g @nativescript/plugin-tools:remove-package",
    "add-demo": "nx g @nativescript/plugin-tools:add-demo",
    "check-demo-parity": "node tools/scripts/check-webview-demo-parity.js",
    "generate-readme": "node tools/scripts/generate-readme.js"
  },
  "private": true,
  "devDependencies": {
    "@nativescript-community/ui-webview": "^1.6.0",
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@nativescript/angular": "^19.0.0",
    "@nativescript/core": "~9.0.0",
    "@nativescript/plugin-tools": "5.5.3",
    "@nativescript/types": "~9.0.0",
    "@nativescript/webpack": "~5.0.35",
    "@ngtools/webpack": "^19.0.0",
    "husky": "~9.0.0",
    "ng-packagr": "^19.0.0",
    "patch-package": "^8.0.1",
    "rxjs": "~7.8.0",
    "sass": "1.53.0",
    "typescript": "~5.6.0",
    "zone.js": "~0.15.0"
  },
  "overrides": {
    "sass": "1.53.0",
    "yargs": "^17.7.2"
  },
  "lint-staged": {
    "**/*.{js,ts,scss,json,html}": [
      "npx prettier --write"
    ]
  }
}
